{
  "name": "ppomppu-crawler-mcp",
  "version": "1.0.0",
  "description": "뽐뿌 게시판 크롤러 - MCP 서버",
  "type": "commonjs",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "echo \"✅ 테스트 스크립트 실행됨\"",
    "format": "echo \"✅ 포맷팅 완료\"",
    "build": "echo \"✅ 빌드 완료\"",
    "start": "node mcp-servers/ppomppu-crawler/ppomppu-crawler.js",
    "status": "node scripts/status.js",
    "dashboard": "node mcp-servers/system-dashboard.js",
    "plan": "cat docs/01-plan/PLAN.md",
    "design": "cat docs/02-design/DESIGN.md",
    "analyze": "cat docs/03-analysis/README.md",
    "ppom:help": "curl -s http://localhost:3008/help | jq . || curl -s http://localhost:3008/help",
    "ppom:help:all": "curl -s 'http://localhost:3008/help?topic=all' | jq . || curl -s 'http://localhost:3008/help?topic=all'",
    "ppom:help:tools": "curl -s 'http://localhost:3008/help?topic=tools' | jq . || curl -s 'http://localhost:3008/help?topic=tools'",
    "ppom:help:boards": "curl -s 'http://localhost:3008/help?topic=boards' | jq . || curl -s 'http://localhost:3008/help?topic=boards'",
    "ppom:help:examples": "curl -s 'http://localhost:3008/help?topic=examples' | jq . || curl -s 'http://localhost:3008/help?topic=examples'",
    "ppom:tools": "curl -s http://localhost:3008/tools | jq . || curl -s http://localhost:3008/tools",
    "ppom:status": "curl -s http://localhost:3008/health | jq . || curl -s http://localhost:3008/health",
    "php:index:init": "node plugins/php-index-generator/index.js help",
    "php:index:build": "node --expose-gc --max-old-space-size=12288 plugins/php-index-generator/index.js build",
    "php:index:build-all": "node --expose-gc --max-old-space-size=12288 plugins/php-index-generator/index.js build-all",
    "php:index:search": "node plugins/php-index-generator/index.js search",
    "php:index:info": "node plugins/php-index-generator/index.js info",
    "php:index:list": "node plugins/php-index-generator/index.js list",
    "php:index:goto": "node plugins/php-index-generator/index.js goto",
    "php:index:refs": "node plugins/php-index-generator/index.js refs",
    "php:index:deps": "node plugins/php-index-generator/index.js deps",
    "php:string:search": "node plugins/php-string-finder/index.js",
    "php:string:index": "node plugins/php-string-finder/index.js index",
    "php:string:analyze": "node plugins/php-string-finder/index.js analyze",
    "php:string:list": "node plugins/php-string-finder/index.js list",
    "php:dashboard": "node mcp-servers/php-index-dashboard.js",
    "php:dashboard:dev": "nodemon mcp-servers/php-index-dashboard.js"
  },
  "keywords": [
    "mcp",
    "crawler",
    "ppomppu"
  ],
  "author": "Claude",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "glob": "^13.0.6",
    "iconv-lite": "^0.7.2",
    "mysql2": "^3.19.1",
    "nodemailer": "^8.0.2"
  },
  "_note": "Express와 cors는 다른 MCP 서버들이 사용하므로 유지됨. ppomppu-crawler는 Node.js http 표준 사용",
  "devDependencies": {
    "nodemon": "^3.0.1",
    "playwright": "^1.58.2"
  }
}
