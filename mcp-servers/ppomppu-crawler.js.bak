/**
 * Ppomppu Crawler MCP Server
 * 뽐뿌 자유게시판(freeboard) 크롤러
 *
 * URL: https://www.ppomppu.co.kr/zboard/zboard.php?id=freeboard&page=X
 */

const express = require('express');
const axios = require('axios');
const cheerio = require('cheerio');
const iconv = require('iconv-lite');

const app = express();
app.use(express.json());

const PORT = process.env.PPOMPPU_PORT || 3008;
const BASE_URL = 'https://www.ppomppu.co.kr/zboard/zboard.php';

/**
 * User-Agent 설정 (웹 크롤링 차단 우회)
 */
const HEADERS = {
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
    'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8',
    'Accept-Language': 'ko-KR,ko;q=0.9,en;q=0.8',
    'Referer': 'https://www.ppomppu.co.kr/'
};

/**
 * 게시판 페이지 크롤링
 */
async function crawlBoard(boardId = 'freeboard', pageNum = 1) {
    try {
        console.log(`🔍 크롤링 시작: ${boardId}, page ${pageNum}`);

        const url = `${BASE_URL}?id=${boardId}&page=${pageNum}`;
        const response = await axios.get(url, {
            headers: HEADERS,
            timeout: 10000,
            responseType: 'arraybuffer'
        });

        // EUC-KR → UTF-8 변환
        const html = iconv.decode(response.data, 'cp949');
        const $ = cheerio.load(html);
        const posts = [];

        // 게시판 리스트 테이블 파싱
        // ppomppu 실제 구조: tr.baseList (notice 제외)
        const rows = $('tr.baseList');

        rows.each((index, element) => {
            try {
                const cells = $(element).find('td');

                // ppomppu HTML 구조:
                // td[0]: number (baseList-numb, colspan=2)
                // td[1]: title+link (baseList-space)
                // td[2]: author (colspan=2)
                // td[3]: date (colspan=2)
                // td[4]: recommend (baseList-rec, colspan=2)
                // td[5]: views (baseList-views, colspan=2)

                const no = $(cells[0]).text().trim();

                // 제목과 링크 추출
                const titleLink = $(cells[1]).find('a.baseList-title');
                // baseball 게시판: <span class="cate_sub">[카테고리]</span> 제목
                // freeboard/ppomppu: <span>제목</span>
                let title = titleLink.find('span').text().trim();
                if (!title || title.startsWith('[')) {
                    // span이 카테고리 태그인 경우, 전체 텍스트에서 추출
                    title = titleLink.text().trim();
                }
                // DEBUG
                if (index === 0) {
                    const spanText = titleLink.find('span').text().trim();
                    const fullText = titleLink.text().trim();
                    console.error(`[DEBUG-${boardId}] spanText="${spanText}", fullText="${fullText.substring(0,80)}"`);
                    console.error(`[DEBUG-${boardId}] title 변수 최종값="${title.substring(0,80)}"`);
                }
                const link = titleLink.attr('href');

                const author = $(cells[2]).text().trim();
                const date = $(cells[3]).text().trim();
                const recommend = $(cells[4]).text().trim();
                const views = $(cells[5]).text().trim();

                // 유효한 데이터만 추가 (게시물 번호가 숫자인 경우만)
                const postNo = parseInt(no, 10);
                if (no && title && link && !isNaN(postNo) && postNo > 0) {
                    // URL 정규화
                    let fullUrl = link;
                    if (!link.startsWith('http')) {
                        if (!link.startsWith('/')) {
                            fullUrl = `/zboard/${link}`;
                        }
                        fullUrl = `https://www.ppomppu.co.kr${fullUrl}`;
                    }

                    posts.push({
                        no: no,
                        title: title,
                        link: link,
                        author: author,
                        date: date,
                        views: views,
                        recommend: recommend,
                        url: fullUrl
                    });
                }
            } catch (err) {
                console.error(`행 파싱 에러: ${err.message}`);
            }
        });

        console.log(`✅ ${posts.length}개 게시물 발견`);
        return posts;

    } catch (error) {
        console.error(`크롤링 오류: ${error.message}`);
        throw error;
    }
}

/**
 * GET /tools - MCP 도구 목록
 */
app.get('/tools', (req, res) => {
    res.json({
        tools: [
            {
                name: 'crawl_board',
                description: '뽐뿌 게시판 페이지 크롤링 (모든 게시판)'
            },
            {
                name: 'get_freeboard',
                description: '자유게시판(freeboard) 특정 페이지 조회'
            },
            {
                name: 'get_ppomppu',
                description: '뽐뿌 일반 게시판(ppomppu) 특정 페이지 조회'
            },
            {
                name: 'get_baseball',
                description: '야구 게시판(baseball) 특정 페이지 조회'
            },
            {
                name: 'get_stock',
                description: '주식 게시판(stock) 특정 페이지 조회'
            }
        ]
    });
});

/**
 * POST /crawl - 게시판 크롤링
 * 요청: { "boardId": "freeboard", "page": 1 }
 */
app.post('/crawl', async (req, res) => {
    try {
        const { boardId = 'freeboard', page = 1 } = req.body;

        if (!boardId || !page || page < 1) {
            return res.json({
                success: false,
                error: '유효하지 않은 boardId 또는 page 번호'
            });
        }

        const posts = await crawlBoard(boardId, page);

        res.json({
            success: true,
            data: {
                boardId: boardId,
                page: page,
                postCount: posts.length,
                posts: posts,
                timestamp: new Date().toISOString()
            },
            message: `${boardId} ${page}페이지에서 ${posts.length}개 게시물을 조회했습니다`
        });

    } catch (error) {
        res.json({
            success: false,
            error: error.message
        });
    }
});

